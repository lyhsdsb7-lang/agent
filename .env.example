# 复制本文件为 .env，然后填写你的云端 API 配置。
# 如果继续使用本地 Ollama，可以保持下面的默认地址和 key。

ERP_AGENT_BASE_URL=http://localhost:11434/v1/
ERP_AGENT_API_KEY=ollama
ERP_AGENT_MODEL=qwen3-vl:8b
ERP_AGENT_TIMEOUT=180

# 示例：DeepSeek OpenAI 兼容接口
# ERP_AGENT_BASE_URL=https://api.deepseek.com/v1/
# ERP_AGENT_API_KEY=sk-xxxxxxxxxxxxxxxx
# ERP_AGENT_MODEL=deepseek-chat

# 示例：OpenAI 官方接口
# ERP_AGENT_BASE_URL=https://api.openai.com/v1/
# ERP_AGENT_API_KEY=sk-xxxxxxxxxxxxxxxx
# ERP_AGENT_MODEL=gpt-4o-mini
